    local function getBed()
        if entitylib.isAlive then
            local id = lplr.Character:GetAttribute('Team')
            for i,v in collectionService:GetTagged('bed') do
                if tonumber(id) == tonumber(v:GetAttribute('TeamId')) then
                    return v
                end
            end
