                                    end
                                end
                            end
                            bedwars.NotificationController:sendInfoNotification({
                                message = '[Bed Alarm]: An intruder is near your bed!',
                            })
                            bedwars.SoundManager:playSound(bedwars.SoundList.BED_ALARM, {
                                volumeMultiplier = Volume.Value
                            })
                        end
