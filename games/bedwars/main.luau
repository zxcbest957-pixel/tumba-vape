            if callback then
                local Notifytick = os.clock()
                local highlight = {}

                repeat
                    local bed, localpos = getBed(), nil
                    if bed then
                        localpos = bed:GetPivot().Position
                    end

                    if localpos then
                        local ent = localpos and entitylib.AllPosition({
                            Origin = localpos,
